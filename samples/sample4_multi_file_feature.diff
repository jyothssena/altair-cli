@@ -0,0 +1,28 @@
+import pytest
+from api.models.user_profile import UserProfile
+
+
+class TestUserProfile:
+    def test_update_from_dict_allowed_fields(self, profile):
+        profile.update_from_dict({"bio": "Hello", "location": "NYC"})
+        assert profile.bio == "Hello"
+        assert profile.location == "NYC"
+
+    def test_update_from_dict_ignores_disallowed(self, profile):
+        profile.update_from_dict({"id": 999, "user_id": 999})
+        assert profile.id != 999
+        assert profile.user_id != 999
+
+    def test_to_dict_returns_expected_keys(self, profile):
+        result = profile.to_dict()
+        expected_keys = {"user_id", "bio", "avatar_url", "location", "website", "updated_at"}
+        assert set(result.keys()) == expected_keys
+
+    def test_update_profile_endpoint(self, client, auth_headers):
+        resp = client.put(
+            "/api/v1/users/1/profile",
+            json={"bio": "Updated bio"},
+            headers=auth_headers,
+        )
+        assert resp.status_code == 200
+        assert resp.json["bio"] == "Updated bio"
